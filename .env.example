# Required: Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Required: PostgreSQL connection string
DATABASE_URL=postgres://verifier:verifier_dev@localhost:5432/verifier_bot

# Required: Chat ID where moderators receive verification requests
DEFAULT_MODERATOR_CHAT_ID=-1001234567890

# Required: Comma-separated Telegram user IDs allowed to moderate
ALLOWED_MODERATOR_IDS=123456789,987654321

# Optional: Path to TOML config file (default: config.toml)
CONFIG_PATH=config.toml

# Optional: Enable webhook mode instead of long polling (default: false)
USE_WEBHOOKS=false

# Optional: Public URL for webhook endpoint (required if USE_WEBHOOKS=true)
PUBLIC_WEBHOOK_URL=https://your-domain.com/webhook

# Optional: Port for webhook HTTP server (default: 8080)
SERVER_PORT=8080

# Optional: Logging filter (default: verifier_bot=info)
RUST_LOG=verifier_bot=debug

# Optional: Set to "production" for JSON log format (default: pretty)
ENVIRONMENT=development
